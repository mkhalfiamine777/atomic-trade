// Social Commerce Schema - Full (Safe Mode) - With Password
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Enums ---
enum UserType {
  INDIVIDUAL
  SHOP
}

enum SubscriptionPlan {
  FREE
  BASIC
  PREMIUM
}

enum ListingType {
  PRODUCT
  REQUEST
}

enum MediaType {
  IMAGE
  VIDEO
}

enum PostType {
  POST
  OFFER
}

enum InteractionType {
  LIKE
  LOVE
  COMMENT
}

// --- Models ---

model User {
  id        String   @id @default(uuid())
  phone     String   @unique
  username  String?  @unique // Added for SEO-friendly URLs
  password  String
  name      String?
  avatarUrl String?
  type      UserType @default(INDIVIDUAL)
  shopCategory String? // e.g. GROCERY, FASHION, TECH
  isVerified Boolean @default(false)
  reputationScore Int @default(100)
  latitude  Float?
  longitude Float?
  subscription SubscriptionPlan @default(FREE)
  walletBalance Float @default(0.0)
  totalSales Int @default(0)
  listings  Listing[]
  stories   MapStory[]
  fiefdoms  ZoneMaster[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Chat Relations
  messagesSent Message[]
  conversationsAsP1 Conversation[] @relation("Participant1")
  conversationsAsP2 Conversation[] @relation("Participant2")

  // Social Relations
  posts SocialPost[]
  interactionsMade     Interaction[] @relation("Actor")
  interactionsReceived Interaction[] @relation("TargetUser")

  @@index([phone])
  @@index([username])
}

model Listing {
  id          String      @id @default(uuid())
  title       String
  description String
  price       Float
  images      String
  type        ListingType @default(PRODUCT)
  category    String?  // e.g. FOOD, ELECTRONICS
  latitude    Float
  longitude   Float
  sellerId    String
  seller      User     @relation(fields: [sellerId], references: [id])
  isSold      Boolean  @default(false)
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  
  conversations Conversation[]
  interactions  Interaction[]

  @@index([sellerId])
  @@index([type])
  @@index([latitude, longitude]) // Spatial Index preparation
}

model MapStory {
  id        String    @id @default(uuid())
  mediaUrl  String    // Renamed from videoUrl
  mediaType MediaType @default(VIDEO)
  caption   String?
  latitude  Float
  longitude Float
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([latitude, longitude])
}

model ZoneMaster {
  id        String   @id @default(uuid())
  zoneName  String
  geoHash   String   @unique
  currentLordId String
  currentLord   User   @relation(fields: [currentLordId], references: [id])
  taxRate       Float
  updatedAt     DateTime @updatedAt

  @@index([geoHash])
}

model Conversation {
  id String @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listingId String? 
  listing Listing? @relation(fields: [listingId], references: [id])

  participant1Id String
  participant1 User @relation("Participant1", fields: [participant1Id], references: [id])
  
  participant2Id String
  participant2 User @relation("Participant2", fields: [participant2Id], references: [id])

  messages Message[]

  @@index([participant1Id])
  @@index([participant2Id])
  @@index([listingId])
}

model Message {
  id String @id @default(uuid())
  createdAt DateTime @default(now())
  
  content String
  
  conversationId String
  conversation Conversation @relation(fields: [conversationId], references: [id])
  
  senderId String
  sender User @relation(fields: [senderId], references: [id])

  @@index([conversationId])
  @@index([senderId])
}

// -----------------------------------------------------------------------------
// GX Social Features (Profile, Posts, Interactions)
// -----------------------------------------------------------------------------

model SocialPost {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  mediaUrl  String
  mediaType MediaType @default(IMAGE)
  caption   String?
  type      PostType  @default(POST)
  createdAt DateTime  @default(now())
  
  // Geo-tagging
  latitude  Float?
  longitude Float?

  // Relations
  interactions Interaction[]

  @@index([userId])
  @@index([createdAt]) // For Feed sorting
  @@index([latitude, longitude]) // For Map View
}

model Interaction {
  id        String          @id @default(uuid())
  type      InteractionType
  content   String?  // For comments
  
  // Actor (Who did it)
  userId    String
  user      User     @relation("Actor", fields: [userId], references: [id])

  // Targets (Polymorphic-ish)
  postId    String?
  post      SocialPost? @relation(fields: [postId], references: [id])

  targetUserId String? // For liking a User Profile directly
  targetUser   User?   @relation("TargetUser", fields: [targetUserId], references: [id])

  listingId    String?
  listing      Listing? @relation(fields: [listingId], references: [id])

  createdAt DateTime @default(now())

  // Performance Indexes
  @@index([userId])
  @@index([postId])
  @@index([targetUserId])
  @@index([listingId])
  @@index([type])
}

