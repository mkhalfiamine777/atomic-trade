// Social Commerce Schema - Full (Safe Mode) - With Password
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Enums ---
enum UserType {
  INDIVIDUAL
  SHOP
  COMPANY
}

enum SubscriptionPlan {
  FREE
  BASIC
  PREMIUM
}

enum ListingType {
  PRODUCT
  REQUEST
}

enum MediaType {
  IMAGE
  VIDEO
}

enum PostType {
  POST
  OFFER
}

enum InteractionType {
  LIKE
  LOVE
  COMMENT
  RATING // Added for Advanced Trust AI (Post-Transaction Reviews)
  WATCH_COMPLETE // Added for Watch-to-Earn (Explore Addiction Engine Phase 3)
}

// --- Models ---

model Category {
  id            String        @id @default(uuid())
  name          String        @unique // e.g. "Electronics"
  icon          String?       // Any associated icon/emoji
  subcategories Subcategory[]
  createdAt     DateTime      @default(now())
}

model Subcategory {
  id          String   @id @default(uuid())
  name        String   // e.g. "Smartphones"
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([categoryId])
}

model User {
  id        String   @id @default(uuid())
  phone     String   @unique
  username  String?  @unique // Added for SEO-friendly URLs
  password  String
  name      String?
  avatarUrl String?
  bio       String?  // User bio / description
  type      UserType @default(INDIVIDUAL)
  shopCategory String? // e.g. GROCERY, FASHION, TECH
  isVerified Boolean @default(false)
  hasCompletedOnboarding Boolean @default(false) // Onboarding status (True = experienced)
  reputationScore Int @default(100)
  latitude  Float?
  longitude Float?
  subscription SubscriptionPlan @default(FREE)
  scheduledDeletionAt DateTime? // Account will be permanently deleted 6 months from this date
  walletBalance Float @default(0.0)
  coins       Int @default(0) // Virtual currency for Watch-to-Earn and gamification
  streakDays  Int @default(0) // Daily active streak for Explore
  lastStreakDate DateTime?    // Last time the streak was updated
  totalSales Int @default(0)
  listings  Listing[]
  stories   MapStory[]
  fiefdoms  ZoneMaster[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Chat Relations
  messagesSent Message[]
  conversationsAsP1 Conversation[] @relation("Participant1")
  conversationsAsP2 Conversation[] @relation("Participant2")

  // Social Relations
  posts SocialPost[]
  interactionsMade     Interaction[] @relation("Actor")
  interactionsReceived Interaction[] @relation("TargetUser")

  // Follow Relations
  followers Follow[] @relation("Following")
  following Follow[] @relation("Followers")

  @@index([phone])
  @@index([username])
}

model Listing {
  id          String      @id @default(uuid())
  title       String
  description String
  price       Float
  images      String
  type        ListingType @default(PRODUCT)
  category    String?  // e.g. FOOD, ELECTRONICS
  subcategory String?  // Standardized identifier from catalog
  latitude    Float
  longitude   Float

  // Crowd Price Drop (Phase 6)
  crowdTarget   Int?     // Target number of likes needed for discount
  crowdDiscount Float?   // Discount amount applied if target reached
  originalPrice Float?   // DI-1: Original price before Crowd Price Drop was applied

  sellerId    String
  seller      User     @relation(fields: [sellerId], references: [id])
  isSold      Boolean  @default(false)
  soldAt      DateTime?
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  
  conversations Conversation[]
  interactions  Interaction[]

  @@index([sellerId])
  @@index([type])
  @@index([latitude, longitude]) // Spatial Index preparation
}

model MapStory {
  id        String    @id @default(uuid())
  mediaUrl  String    // Renamed from videoUrl
  mediaType MediaType @default(VIDEO)
  caption   String?
  latitude  Float
  longitude Float
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([latitude, longitude])
}

model ZoneMaster {
  id        String   @id @default(uuid())
  zoneName  String
  geoHash   String   @unique
  currentLordId String
  currentLord   User   @relation(fields: [currentLordId], references: [id])
  taxRate       Float
  updatedAt     DateTime @updatedAt

  @@index([geoHash])
}

model Conversation {
  id String @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listingId String? 
  listing Listing? @relation(fields: [listingId], references: [id])

  participant1Id String
  participant1 User @relation("Participant1", fields: [participant1Id], references: [id])
  
  participant2Id String
  participant2 User @relation("Participant2", fields: [participant2Id], references: [id])

  messages Message[]

  @@index([participant1Id])
  @@index([participant2Id])
  @@index([listingId])
}

model Message {
  id String @id @default(uuid())
  createdAt DateTime @default(now())
  
  content String
  
  conversationId String
  conversation Conversation @relation(fields: [conversationId], references: [id])
  
  senderId String
  sender User @relation(fields: [senderId], references: [id])

  @@index([conversationId])
  @@index([senderId])
}

// -----------------------------------------------------------------------------
// GX Social Features (Profile, Posts, Interactions)
// -----------------------------------------------------------------------------

model SocialPost {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  mediaUrl  String
  mediaType MediaType @default(IMAGE)
  caption   String?
  type      PostType  @default(POST)
  createdAt DateTime  @default(now())
  
  // Geo-tagging
  latitude  Float?
  longitude Float?

  // Relations
  interactions Interaction[]

  @@index([userId])
  @@index([createdAt]) // For Feed sorting
  @@index([latitude, longitude]) // For Map View
}

model Interaction {
  id        String          @id @default(uuid())
  type      InteractionType
  content   String?  // For comments
  rating    Int?     // For star ratings (1-5)
  
  // Actor (Who did it)
  userId    String
  user      User     @relation("Actor", fields: [userId], references: [id])

  // Targets (Polymorphic-ish)
  postId    String?
  post      SocialPost? @relation(fields: [postId], references: [id])

  targetUserId String? // For liking a User Profile directly
  targetUser   User?   @relation("TargetUser", fields: [targetUserId], references: [id])

  listingId    String?
  listing      Listing? @relation(fields: [listingId], references: [id])

  createdAt DateTime @default(now())

  // Performance Indexes
  @@index([userId])
  @@index([postId])
  @@index([targetUserId])
  @@index([listingId])
  @@index([type])

  // Prevent duplicate interactions (e.g. double-likes from race conditions)
  @@unique([userId, postId, type])
  @@unique([userId, listingId, type])
  @@unique([userId, targetUserId, type])
}

// Follow System
model Follow {
  id          String   @id @default(uuid())
  followerId  String
  follower    User     @relation("Followers", fields: [followerId], references: [id])
  followingId String
  following   User     @relation("Following", fields: [followingId], references: [id])
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

