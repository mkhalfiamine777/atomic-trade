# ─── Admin Access ────────────────────────────────────────
# Comma-separated list of phone numbers strictly authorized for admin access.
ADMIN_PHONES="06XXXXXXXX,07XXXXXXXX"

# ─── Local Development Database (Docker) ─────────────────
# The local PostgreSQL connection string. Ensure Docker is running.
DATABASE_URL="postgresql://postgres:password@localhost:5432/social_commerce?schema=public"

# ─── Production Database (Railway/Neon) ──────────────────
# Do not use the production database string locally to avoid corrupting user data!
# DATABASE_URL="postgresql://..."

# ─── Uploadthing (Images & Videos) ───────────────────────
# Get this from https://uploadthing.com -> Dashboard -> Your Project -> API Keys
UPLOADTHING_SECRET="sk_live_..."
UPLOADTHING_APP_ID="abc123def4"
UPLOADTHING_TOKEN="eyJ..."

# ─── Socket.io Configuration ─────────────────────────────
# Set to your local or deployed URL.
NEXT_PUBLIC_SOCKET_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Upstash Redis (For Rate Limiting & Caching) ─────────
# Get this from https://console.upstash.com -> Redis -> REST API section
UPSTASH_REDIS_REST_URL="https://...upstash.io"
UPSTASH_REDIS_REST_TOKEN="AeTM..."
